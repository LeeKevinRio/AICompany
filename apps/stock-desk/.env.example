# stock-desk 環境變數範本 — 只放假值,真值放同目錄的 .env(已被 .gitignore)。
# Phase 1 尚無外部資料源;之後接資料源 / 警示 webhook 時在此擴充。

# 前端(瀏覽器端)呼叫後端 API 的位址
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# 之後的 Phase 才會用到(先留範例假值,不填也能跑):
# FINMIND_API_TOKEN=your-token-here
# ALERT_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
# ALERT_TELEGRAM_BOT_TOKEN=your-token-here
